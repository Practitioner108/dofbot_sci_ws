<?xml version="1.0"?>
<launch>
  <!-- MuJoCo 仿真 + ros_control 闭环启动
       用法:
         roslaunch dofbot_control dofbot_sim.launch               # 带查看器
         roslaunch dofbot_control dofbot_sim.launch headless:=true  # 无头模式
  -->
  <arg name="control_freq" default="50" />
  <arg name="headless" default="false" />

  <!-- 1. 加载机器人描述 -->
  <param name="robot_description"
    command="xacro $(find dofbot_description)/urdf/dofbot.xacro" />

  <!-- 2. 加载控制器参数 -->
  <rosparam file="$(find dofbot_control)/config/dofbot_control.yaml" command="load" />

  <!-- 3. MuJoCo 仿真节点 -->
  <include file="$(find dofbot_control)/launch/mujoco_sim.launch">
    <arg name="headless" value="$(arg headless)" />
    <arg name="control_freq" value="$(arg control_freq)" />
  </include>

  <!-- 4. 硬件节点 (DofbotSimInterface, ROS Topic 桥接) -->
  <node name="dofbot_hw_node" pkg="dofbot_control" type="dofbot_hw_node" output="screen">
    <param name="sim_mode" value="true" />
    <param name="control_freq" value="$(arg control_freq)" />
  </node>

  <!-- 5. robot_state_publisher: 读 /joint_states → TF -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
    <param name="publish_frequency" value="$(arg control_freq)" />
  </node>

  <!-- 6. mimic_joint_publisher: 从 MuJoCo /joint_states_raw 补全 URDF mimic → /joint_states -->
  <node name="mimic_joint_publisher" pkg="joint_state_publisher" type="joint_state_publisher">
    <rosparam param="source_list">[/joint_states_raw]</rosparam>
    <param name="use_mimic_tag" value="true" />
  </node>

  <!-- 7. controller_spawner: 只启动轨迹控制器（仿真下 joint_state 由 MuJoCo 直接发布） -->
  <node name="controller_spawner" pkg="controller_manager" type="spawner"
        args="--namespace / dofbot_trajectory_controller" />
</launch>
