<?xml version="1.0"?>
<launch>
  <!--
    MuJoCo 仿真启动文件
    用法:
      roslaunch dofbot_mujoco mujoco_sim.launch           # 带查看器
      roslaunch dofbot_mujoco mujoco_sim.launch headless:=true  # 无头模式 (用于 ros_control 闭环)
  -->
  <arg name="headless" default="false" />

  <node name="dofbot_mujoco_sim" pkg="dofbot_mujoco" type="mujoco_sim_node.py" output="screen">
    <param name="headless" value="$(arg headless)" />
  </node>

  <!-- robot_state_publisher 读取 /joint_states 并广播 TF -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" if="$(arg headless)">
    <param name="publish_frequency" value="100.0" />
  </node>
</launch>
