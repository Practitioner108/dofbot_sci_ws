<?xml version="1.0" encoding="utf-8"?>
<robot name="dofbot">
    <link name="base_link">
        <inertial>
            <mass value="0.369776"/>
            <origin xyz="0.000065 -0.048265 0.021267" rpy="0 0 0"/>
            <inertia ixx="0.00206195" ixy="-0.00000069" ixz="-0.00000073"
                     iyy="0.00062736" iyz="-0.00032039" izz="0.00210250"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://dofbot_description/meshes/base_link.STL"/>
            </geometry>
            <material name="grey_material">
                <color rgba="0.7 0.7 0.7 1"/>
