        <parent link="link5"/>
        <child link="left_finger"/>
        <axis xyz="1 0 0"/>
        <limit lower="-0.03" upper="0.03" effort="5.0" velocity="0.5"/>
        <dynamics damping="0.1" friction="0.05"/>
    </joint>

    <link name="right_finger">
